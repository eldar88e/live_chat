<div class="flex min-h-screen items-center justify-center px-4">
  <div class="w-full max-w-md space-y-6 rounded-2xl bg-white p-8 shadow-lg">
    <h2 class="text-center text-2xl font-bold text-gray-900">Вход</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :password, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
          <%= f.label :remember_me, class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Войти", class: "w-full cursor-pointer rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:outline-none" %>
      </div>
    <% end %>

    <div class="space-y-2 text-center text-sm">
      <%- if devise_mapping.registerable? %>
        <%#= link_to "Регистрация", new_registration_path(resource_name), data: { turbo_prefetch: false }, class: "text-blue-600 hover:text-blue-800 hover:underline" %><br />
      <% end %>

      <%- if devise_mapping.recoverable? %>
        <%= link_to "Забыли пароль?", new_password_path(resource_name), data: { turbo_prefetch: false }, class: "text-blue-600 hover:text-blue-800 hover:underline" %>
      <% end %>
    </div>
  </div>
</div>
