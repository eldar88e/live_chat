<div class="flex min-h-screen items-center justify-center px-4">
  <div class="w-full max-w-md space-y-6 rounded-2xl bg-white p-8 shadow-lg">
    <h2 class="text-center text-2xl font-bold text-gray-900">Восстановление пароля</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none" %>
      </div>

      <div>
        <%= f.submit "Отправить инструкции", class: "w-full cursor-pointer rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:outline-none" %>
      </div>
    <% end %>

    <div class="text-center text-sm">
      <%= link_to "Вернуться ко входу", new_session_path(resource_name), data: { turbo_prefetch: false }, class: "text-blue-600 hover:text-blue-800 hover:underline" %>
    </div>
  </div>
</div>
